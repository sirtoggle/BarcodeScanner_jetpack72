# Copy this file to scanner.env for settings that must survive reboot.
# The boot-service installer creates scanner.env automatically when it is absent.

# Recommended: set the exact number of digits in the printed ID.
# ID_EXPECTED_LENGTH=8

# Logo phrases that must not be saved as names are listed in logo_words.txt.

# Disable touchscreen devices when the scanner starts. Mouse and keyboard input
# remain available. If automatic matching misses the monitor, set a distinctive
# part of the device name reported by: xinput list --name-only
ID_SCANNER_DISABLE_TOUCH=true
# ID_SCANNER_TOUCH_MATCH='ILITEK|Multi-Touch'

# Optional fixed USB path. Leave unset to detect the currently mounted daily stick.
# ID_SCANNER_OUTPUT_DIR=/media/your_username/USB_NAME

# Other optional examples:
# ID_PATTERN='12[0-9]{6}'
# DISPLAY_MAX_WIDTH=960
# ID_SCANNER_FULLSCREEN=true
# ID_SCANNER_SAVE_IMAGES=true
